# Copy to .env and adjust. Local default is SQLite (zero setup).
# Team/prod target is Postgres — uncomment and set:
# DATABASE_URL=postgresql+psycopg://assetflow:assetflow@localhost:5432/assetflow
DATABASE_URL=sqlite:///./assetflow.db

# Auth
SECRET_KEY=dev-secret-change-me-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=720

# CORS (React dev server)
FRONTEND_ORIGIN=http://localhost:5173
